# Telegram BotFather token (Railway Variables'da tanımlayın)
BOT_TOKEN=your_bot_token_here

# Yetkililer — en az biri gerekli (ikisi birlikte de olabilir)
# Sayısal ID: @userinfobot ile öğrenilir
ADMIN_IDS=123456789
# Telegram kullanıcı adları (@ olmadan, virgülle) — Railway için pratik
ADMIN_USERNAMES=kadirbasgoren,baska_admin

# Boş bırakılırsa botun eklendiği tüm gruplarda çalışır
# ALLOWED_GROUP_IDS=-1001234567890

# Railway PostgreSQL eklentisi DATABASE_URL'i otomatik verir.
# Yerel geliştirme için boş bırakın → data/bilgibotu.db kullanılır
# DATABASE_URL=postgresql://user:pass@host:5432/railway

MATCH_THRESHOLD=82
MIN_QUERY_WORDS=2
COOLDOWN_SECONDS=2
CACHE_TTL_SECONDS=30
QUESTIONS_PAGE_SIZE=20
